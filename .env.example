# Скопируйте в `.env.local` и заполните. Секреты не коммитить.

# --- Источник данных ---
# Локально без DATABASE_URL приложение по умолчанию в режиме mock (в памяти).
# Режим postgres: задайте URL ниже (и JWT_SECRET для сессии).
#
# Production: обязательны DATABASE_URL и JWT_SECRET; mock в памяти запрещён.
# Персональные данные для РФ — хостинг PostgreSQL в РФ, см. db/README.md

# Docker из этого репозитория: порт 5433 на ПК (5432 часто занят PostgreSQL в Windows)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/trainly"

# Только свой Postgres на 5432 без Docker:
# DATABASE_URL="postgresql://ИМЯ:ПАРОЛЬ@127.0.0.1:5432/trainly"

# true = всегда mock; false = принудительно postgres (нужен DATABASE_URL).
# В production runtime TRAINLY_USE_MOCK_DATA=true вызывает ошибку конфигурации.
# TRAINLY_USE_MOCK_DATA=false

# --- Режимы dev (важно для навигации с /welcome) ---
# | Режим | Поведение |
# |-------|-----------|
# | Нет DATABASE_URL | mock: все маршруты UI без JWT; кнопки welcome ведут в /overview. |
# | DATABASE_URL + нет cookie | postgres: middleware редиректит /overview → /welcome; welcome ведёт на /auth; при TRAINLY_DEV_AUTH_SECRET на /auth есть «Dev: войти». |
# | DATABASE_URL + cookie | полный UI как в prod. |
# | TRAINLY_USE_MOCK_DATA=true | принудительно mock при наличии DATABASE_URL. |

# JWT сессия тренера: минимум 16 символов (lib/auth/jwt.ts); для prod лучше ≥32
JWT_SECRET="replace-with-a-long-random-secret-minimum-32-chars"

# Опционально: лимит пула (lib/db/server.ts)
# DB_POOL_MAX=10

# Telegram Bot token для валидации initData (app/api/auth/telegram/route.ts)
TELEGRAM_BOT_TOKEN=

# Dev-вход: секрет для app/api/auth/dev (только вне production; в prod маршрут отключён)
# TRAINLY_DEV_AUTH_SECRET=

# Публичный URL (return_url ЮKassa)
# TRAINLY_PUBLIC_URL=https://app.example.com
# NEXT_PUBLIC_APP_URL=https://app.example.com

# ЮKassa
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# YOOKASSA_REQUIRE_API_VERIFY=true

# Вебхук: заголовок X-Trainly-Yookassa-Secret
# TRAINLY_YOOKASSA_WEBHOOK_SECRET=
# Staging only: query trainly_webhook_secret
# TRAINLY_YOOKASSA_WEBHOOK_ALLOW_QUERY_SECRET=false

# Длительность trial для новых тренеров (дней), см. lib/server/ensureTrainer.ts
# TRAINLY_TRIAL_DAYS=14

# Ссылка на поддержку для экрана /support (публичная, можно https://t.me/username)
# NEXT_PUBLIC_TRAINLY_SUPPORT_URL=https://t.me/your_support

# Разрешить npm run db:seed в NODE_ENV=production (только осознанно)
# TRAINLY_ALLOW_SEED=false
